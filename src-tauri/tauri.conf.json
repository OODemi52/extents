{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Extents",
  "version": "0.4.4",
  "identifier": "com.extents.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "hiddenTitle": true,
        "title": "Extents",
        "visible": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$CACHE/**",
          "$APPDATA/**",
          "$RESOURCE/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../legal/THIRD_PARTY_NOTICES.md": "legal/THIRD_PARTY_NOTICES.md",
      "../legal/LICENSING.md": "legal/EXTENTS-LICENSING.md",
      "../legal/LGPL-2.1.txt": "legal/RAWLER-LGPL-2.1.txt",
      "../legal/RELINKING.md": "legal/RAWLER-RELINKING.md"
    },
    "macOS": {
      "bundleName": "Extents"
    }
  }
}
